# Marker-Anchored AR Asset Platform — environment template. Copy to .env (gitignored) and fill in.

# Postgres (Phase 0). Managed Postgres (Railway/Supabase/Neon) REQUIRES sslmode=require,
# and slow proxies (e.g. Railway) need a longer connect_timeout or Prisma reports a false
# "P1001 can't reach database server". Include both:
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/db?schema=public&sslmode=require&connect_timeout=30"

# The GPU worker: the existing Python pipeline (generation/server.py) the web app enqueues jobs to.
# Phase 0 starts by calling it over HTTP; a real queue is added when load needs it.
GEN_WORKER_URL="http://localhost:8077"

# Object storage / CDN (S3-compatible, e.g. Cloudflare R2). Added when publish lands assets to CDN.
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_BASE_URL=""

# Auth — Clerk (https://dashboard.clerk.com → API keys).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# Optional: route sign-in/up to hosted pages.
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# Stripe (wired next).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
